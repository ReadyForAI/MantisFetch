# MantisFetch configuration template.
# Copy to `.env` (git-ignored) and fill in the values you need.
# All variables are optional unless noted; defaults are shown after each key.
# Full reference: README.md "Environment variables".

# ── LLM (summaries + OCR) ─────────────────────────────────────────────
# Backend: "gemini" or "openai" (OpenAI-compatible). Configure exactly one of
# the two blocks below.

# --- Gemini backend (default) ---
MANTISFETCH_LLM_PROVIDER=gemini
GEMINI_API_KEY=

# --- OpenAI-compatible backend ---
# To use this instead of Gemini, comment out the two Gemini lines above and
# uncomment this block. Vendor profile: openai | zhipu | kimi | aliyun | volcengine
# MANTISFETCH_LLM_PROVIDER=openai
# MANTISFETCH_LLM_VENDOR=openai
# MANTISFETCH_LLM_API_KEY=
# MANTISFETCH_LLM_BASE_URL=        # override; defaults to the vendor profile URL
# MANTISFETCH_LLM_MODEL=           # override; defaults to the vendor profile model
# MANTISFETCH_OCR_MODEL=           # optional OCR vision model (defaults to LLM_MODEL)

# ── Auth (REST + MCP) ─────────────────────────────────────────────────
# Bearer token required by /web, /doc and the MCP server. Strongly recommended
# when the service is reachable beyond loopback (compose publishes 9898).
# MANTISFETCH_MCP_TOKEN=
# Host allowlist for the MCP gate (comma-separated host[:port] globs).
# MANTISFETCH_MCP_ALLOWED_HOSTS=

# ── TLS (optional) ────────────────────────────────────────────────────
# MANTISFETCH_TLS_CERTFILE=/certs/cert.pem
# MANTISFETCH_TLS_KEYFILE=/certs/key.pem

# ── Storage ───────────────────────────────────────────────────────────
# MANTISFETCH_DOCS_DIR=~/.mantisfetch/docs
# MANTISFETCH_STORE_SOURCE_FILES=true

# ── Web search (disabled unless MANTISFETCH_SEARCH_PROVIDER is set) ────
# Provider: tavily | bocha | brave | searxng
# MANTISFETCH_SEARCH_PROVIDER=
# MANTISFETCH_SEARCH_API_KEY=
# MANTISFETCH_SEARXNG_URL=         # required for the searxng provider

# ── Summary / OCR concurrency (tuning; defaults are sensible) ──────────
# MANTISFETCH_SUMMARY_MODE=defer
# MANTISFETCH_MAX_CONCURRENT_PARSE=2
# MANTISFETCH_LOCAL_OCR_CONCURRENCY=1
# MANTISFETCH_DEFERRED_SUMMARY_MAX_CONCURRENT=1
