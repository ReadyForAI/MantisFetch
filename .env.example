# MantisFetch configuration template.
# Copy to `.env` (git-ignored) and fill in the values you need.
# All variables are optional unless noted; defaults are shown after each key.
# Full reference: README.md "Environment variables".

# ── LLM (summaries + OCR) ─────────────────────────────────────────────
# Backend: "gemini" or "openai" (OpenAI-compatible). Configure exactly one of
# the two blocks below.

# --- Gemini backend (default) ---
MANTISFETCH_LLM_PROVIDER=gemini
GEMINI_API_KEY=

# --- OpenAI-compatible backend ---
# To use this instead of Gemini, comment out the two Gemini lines above and
# uncomment this block. Vendor profile: openai | zhipu | kimi | aliyun | volcengine
# MANTISFETCH_LLM_PROVIDER=openai
# MANTISFETCH_LLM_VENDOR=openai
# MANTISFETCH_LLM_API_KEY=
# MANTISFETCH_LLM_BASE_URL=        # override; defaults to the vendor profile URL
# MANTISFETCH_LLM_MODEL=           # override; defaults to the vendor profile model
# MANTISFETCH_OCR_MODEL=           # optional OCR vision model (defaults to LLM_MODEL)

# --- Per-role providers + failover (dual-slot) ---
# The block above configures one provider shared by both roles. To run OCR and
# summarisation on DIFFERENT vendors and fail over to a backup, set
# MANTISFETCH_LLM_DEFAULT (this switches on the dual-slot scheme). Two credential
# slots (DEFAULT, EXTRA); each role picks a primary + optional fallback model
# written "<vendor>/<model>" — the vendor prefix routes to the matching slot.
# base_url/api_key are read here, not baked into the image (point a slot at any
# OpenAI-compatible endpoint via its _BASE_URL).
# MANTISFETCH_LLM_DEFAULT=zhipu
# MANTISFETCH_LLM_DEFAULT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MANTISFETCH_LLM_DEFAULT_API_KEY=
# MANTISFETCH_LLM_EXTRA=deepseek
# MANTISFETCH_LLM_EXTRA_BASE_URL=https://api.deepseek.com/v1
# MANTISFETCH_LLM_EXTRA_API_KEY=
# MANTISFETCH_SUM_MODEL_DEFAULT=deepseek/deepseek-chat
# MANTISFETCH_SUM_MODEL_FALLBACK=zhipu/glm-4.6
# MANTISFETCH_OCR_MODEL_DEFAULT=zhipu/glm-4.6v
# MANTISFETCH_OCR_MODEL_FALLBACK=deepseek/deepseek-chat

# ── Auth (REST + MCP) ─────────────────────────────────────────────────
# Bearer token required by /web, /doc and the MCP server. Strongly recommended
# when the service is reachable beyond loopback (compose publishes 9898).
# MANTISFETCH_MCP_TOKEN=
# Host allowlist for the MCP gate (comma-separated host[:port] globs).
# MANTISFETCH_MCP_ALLOWED_HOSTS=

# ── TLS (optional) ────────────────────────────────────────────────────
# MANTISFETCH_TLS_CERTFILE=/certs/cert.pem
# MANTISFETCH_TLS_KEYFILE=/certs/key.pem

# ── Storage ───────────────────────────────────────────────────────────
# MANTISFETCH_DOCS_DIR=~/.mantisfetch/docs
# MANTISFETCH_STORE_SOURCE_FILES=true

# ── Deliverables (read-only GET /deliverables byte face; unset = disabled) ────
# Fence root for agent deliverable downloads. No default: unset → every request
# 404s (face disabled). Must not overlap MANTISFETCH_DOCS_DIR or the doc_parse
# fence (MANTISFETCH_ALLOWED_DOC_ROOTS).
# MANTISFETCH_DELIVERABLES_ROOT=
# MANTISFETCH_DELIVERABLES_MAX_MB=200

# ── Web capture cache ────────────────────────────────────────────────
# URL-level reuse for POST /web/capture (0 = off, default). force_refresh bypasses.
# MANTISFETCH_CAPTURE_TTL_HOURS=0
# URL-level reuse for POST /web/search_and_capture only (default 24h). Content-hash
# library-wide reuse always runs after distill for both endpoints (unless force_refresh).
# MANTISFETCH_SEARCH_CAPTURE_TTL_HOURS=24

# ── Web search (disabled unless MANTISFETCH_SEARCH_PROVIDER is set) ────
# Provider: tavily | bocha | brave | searxng
# MANTISFETCH_SEARCH_PROVIDER=
# MANTISFETCH_SEARCH_API_KEY=      # shared API key (fallback for tavily/bocha/brave)
# Per-provider keys take precedence over the shared one — set these to run
# more than one API provider at once (e.g. bocha for CN + tavily for EN):
# MANTISFETCH_TAVILY_API_KEY=
# MANTISFETCH_BOCHA_API_KEY=
# MANTISFETCH_BRAVE_API_KEY=
# Addressable set for per-request `provider` selection (adds to primary + fallback).
# Lets an agent target one backend per call — e.g. bocha for a Chinese query and
# tavily for an English one — keeping the two result sets apart:
# MANTISFETCH_SEARCH_PROVIDERS=bocha,tavily
# MANTISFETCH_SEARXNG_URL=         # required for the searxng provider

# ── Summary / OCR concurrency (tuning; defaults are sensible) ──────────
# MANTISFETCH_SUMMARY_MODE=defer
# MANTISFETCH_MAX_CONCURRENT_PARSE=2
# MANTISFETCH_LOCAL_OCR_CONCURRENCY=1
# MANTISFETCH_DEFERRED_SUMMARY_MAX_CONCURRENT=1
