{
  "profile": "bid_cn",
  "section_policy": {
    "toc_max_level": 2,
    "suppress_arabic_clause_headings_when_formal_chinese": true,
    "formal_chinese_min_headings": 4
  },
  "summary_policy": {
    "default_mode": "defer",
    "async_modes": ["fast", "accurate"],
    "sync_modes": ["full"]
  },
  "table_policy": {
    "prefer_markitdown": true
  },
  "fields": [
    {
      "id": "project_no",
      "aliases": ["项目编号", "采购编号", "招标编号"],
      "pattern": "(?:项目编号|采购编号|招标编号)\\s*[：:]\\s*([A-Za-z0-9][A-Za-z0-9\\-]+)"
    },
    {
      "id": "project_name",
      "aliases": ["项目名称", "采购项目名称"],
      "pattern": "(?:项目名称|采购项目名称)\\s*[：:]\\s*([^\\n]+)"
    },
    {
      "id": "procurement_method",
      "aliases": ["采购方式", "招标方式", "单一来源", "公开招标", "竞争性谈判"],
      "pattern": "(?:(?:采购方式|招标方式)\\s*[：:]\\s*([^\\n]+)|(公开招标|邀请招标|单一来源|竞争性谈判|竞争性磋商|询价|框架协议)采购?文件)"
    },
    {
      "id": "purchaser_name",
      "aliases": ["采购人", "招标人", "采购单位"],
      "pattern": "(?:采购人|招标人|采购单位)\\s*(?:名称)?\\s*[：:]\\s*([^\\n]+)"
    },
    {
      "id": "agent_name",
      "aliases": ["采购代理机构", "招标代理机构", "代理机构"],
      "pattern": "(?:采购代理机构|招标代理机构|代理机构)\\s*(?:名称)?\\s*[：:]\\s*([^\\n]+)"
    },
    {
      "id": "budget_amount",
      "aliases": ["预算金额", "项目预算", "采购预算", "最高限价"],
      "pattern": "(?:预算金额|项目预算|采购预算|最高限价)\\s*(?:（[^）]*）|\\([^)]*\\))?\\s*[：:]\\s*(?:人民币)?\\s*¥?\\s*([\\d,]+(?:\\.\\d+)?)\\s*(?:元|万元)?"
    },
    {
      "id": "bid_deposit",
      "aliases": ["投标保证金", "响应保证金", "履约保证金"],
      "pattern": "(?:投标保证金|响应保证金|履约保证金)\\s*(?:（[^）]*）|\\([^)]*\\))?\\s*[：:]?\\s*(?:人民币)?\\s*¥?\\s*([\\d,]+(?:\\.\\d+)?)\\s*(?:元|万元)?"
    },
    {
      "id": "bid_opening_time",
      "aliases": ["开标时间", "谈判时间", "响应时间", "磋商时间"],
      "pattern": "(?:开标时间|谈判时间|响应时间|磋商时间)\\s*[：:]\\s*([^\\n]+)"
    },
    {
      "id": "bid_opening_location",
      "aliases": ["开标地点", "谈判地点", "响应地点", "磋商地点"],
      "pattern": "(?:开标地点|谈判地点|响应地点|磋商地点)\\s*[：:]\\s*([^\\n]+)"
    },
    {
      "id": "submission_deadline",
      "aliases": ["投标文件递交截止时间", "响应文件递交截止时间", "递交截止时间", "投标截止时间"],
      "pattern": "(?:投标文件?递交截止时间|响应文件?递交截止时间|递交截止时间|投标截止时间)\\s*[：:]\\s*([^\\n]+)"
    },
    {
      "id": "contact_person",
      "aliases": ["联系人", "联 系 人"],
      "pattern": "联\\s*系\\s*人\\s*[：:]\\s*([^\\n]+)"
    },
    {
      "id": "contact_phone",
      "aliases": ["联系电话", "电话"],
      "pattern": "联系电话\\s*[：:]\\s*([^\\n]+)"
    },
    {
      "id": "contact_email",
      "aliases": ["电子邮箱", "邮箱", "Email"],
      "pattern": "(?:电子邮箱|电子邮件|邮箱|Email|E-mail)\\s*[：:]\\s*([\\w.+-]+@[\\w-]+(?:\\.[\\w-]+)+)"
    }
  ]
}
