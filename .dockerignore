# Version control
.git
.gitignore

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv
venv
env

# Test artifacts
.pytest_cache
.ruff_cache
htmlcov
.coverage

# Editor / OS
.DS_Store
*.swp
*.swo
.idea
.vscode

# Secrets / local config — injected via env or mounted read-only at runtime;
# NEVER bake into the image (COPY . . would otherwise leak the private key and
# the API keys / MCP bearer token into the build layers).
.env
.env.*
certs/

# Runtime data (mounted as a volume)
docs/

# CI / dev-only config
.github
.claude

# Documentation (not needed at runtime)
*.md
